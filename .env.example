# Скопіюй цей файл у ".env" і встав свої ключі.

# Google Gemini (транскрипція аудіо) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude (аналіз випадку) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Необов'язкові налаштування (можна не чіпати) ---
# Модель Gemini для транскрипції
GEMINI_MODEL=gemini-2.5-flash
# Модель Claude для аналізу (claude-opus-4-8 = найкраща якість; claude-sonnet-4-6 = швидше/дешевше)
CLAUDE_MODEL=claude-opus-4-8
# Порт локального сервера
PORT=5173
