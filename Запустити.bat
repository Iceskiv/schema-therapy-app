@echo off
chcp 65001 >nul
cd /d "%~dp0"
echo ================================================
echo   Схема-терапія: концептуалізація випадку
echo ================================================
if not exist node_modules (
  echo Перший запуск: встановлюю залежності, зачекай...
  call npm install
)
echo Відкриваю браузер: http://localhost:5180
start "" http://localhost:5180
echo (Якщо сторінка не відкрилась одразу - онови її через кілька секунд)
echo Щоб зупинити - закрий це вікно.
call npm start
pause
